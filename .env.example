# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=learning_platform
DB_USER=postgres
DB_PASSWORD=password

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=learning_platform:

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Service Ports
GATEWAY_PORT=3000
AUTH_PORT=3001
USERS_PORT=3002
COURSES_PORT=3003
PROGRESS_PORT=3004
ANALYTICS_PORT=3005
CONTENT_PORT=3006

# Service URLs
AUTH_SERVICE_URL=http://localhost:3001
USERS_SERVICE_URL=http://localhost:3002
COURSES_SERVICE_URL=http://localhost:3003
PROGRESS_SERVICE_URL=http://localhost:3004
ANALYTICS_SERVICE_URL=http://localhost:3005
CONTENT_SERVICE_URL=http://localhost:3006

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@learningplatform.com

# AWS Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET=learning-platform-content
CLOUDFRONT_DOMAIN=your-cloudfront-domain.cloudfront.net

# File Upload Configuration
MAX_FILE_SIZE=52428800
UPLOAD_PATH=uploads
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx,mp4,avi,mov

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_DIR=logs

# Environment
NODE_ENV=development
ENVIRONMENT=development

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_PASSWORD=admin

# Webhook Configuration
WEBHOOK_SECRET=your-webhook-secret
WEBHOOK_TIMEOUT=30000
WEBHOOK_RETRY_ATTEMPTS=3

# Analytics Configuration
ANALYTICS_BATCH_SIZE=100
ANALYTICS_FLUSH_INTERVAL=60000

# Content Processing Configuration
VIDEO_QUALITY=720p
THUMBNAIL_WIDTH=1280
THUMBNAIL_HEIGHT=720
FFMPEG_PATH=/usr/bin/ffmpeg

# Security
BCRYPT_ROUNDS=12
SESSION_SECRET=your-session-secret-change-this
COOKIE_SECRET=your-cookie-secret-change-this

# Cache Configuration
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# Queue Configuration
QUEUE_CONCURRENCY=5
QUEUE_MAX_ATTEMPTS=3
QUEUE_BACKOFF_DELAY=2000

# API Configuration
API_VERSION=v1
API_PREFIX=/api
API_DOCS_ENABLED=true

# Feature Flags
ENABLE_EMAIL_VERIFICATION=true
ENABLE_WEBSOCKETS=true
ENABLE_ANALYTICS=true
ENABLE_CONTENT_PROCESSING=true
ENABLE_WEBHOOKS=true

# External Services
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# Search Configuration
ELASTICSEARCH_HOST=localhost:9200
ELASTICSEARCH_INDEX=learning_platform

# Backup Configuration
BACKUP_ENABLED=false
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=learning-platform-backups

# Development Configuration
DEBUG=false
HOT_RELOAD=true
MOCK_EXTERNAL_SERVICES=false

# Testing Configuration
TEST_DB_NAME=learning_platform_test
TEST_REDIS_DB=1
MOCK_EMAIL=true
